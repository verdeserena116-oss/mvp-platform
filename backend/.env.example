# Server
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campaigns_platform
DB_USER=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Email (SendGrid SMTP example)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=no-reply@yourdomain.com

# WhatsApp (Z-API) - note: instance ID and token are configured per-operation
# via the Operation record (whatsappInstanceId, whatsappToken), not globally.
ZAPI_BASE_URL=https://api.z-api.io/instances
